{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": ".",
    "outDir": "./dist",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}